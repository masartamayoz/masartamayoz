{
  "entities": {
    "User": {
      "title": "المستخدم",
      "description": "بيانات المستخدم الأساسية",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "parent", "teacher", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "pending", "none"] },
        "subscriptionStart": { "type": "string", "format": "date-time" },
        "subscriptionEnd": { "type": "string", "format": "date-time" },
        "level": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "userType"]
    },
    "Video": {
      "title": "درس تعليمي",
      "description": "فيديو تعليمي مع بيانات المحتوى",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoUrls": { "type": "array", "items": { "type": "string" } },
        "chapter": { "type": "string" },
        "level": { "type": "string" },
        "type": { "type": "string", "enum": ["lesson", "exercise", "assignment", "synthesis"] },
        "category": { "type": "string" },
        "trimester": { "type": "string", "enum": ["1", "2", "3"] },
        "modelNumber": { "type": "string" },
        "order": { "type": "number" },
        "isFree": { "type": "boolean" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "pdfText": { "type": "string" },
        "pdfSolution": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Receipt": {
      "title": "وصل خلاص",
      "description": "بيانات وصلات الخلاص المرفوعة من الطلاب",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "receiptURL": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "level": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Group": {
      "title": "مجموعة تعليمية",
      "description": "مجموعات الطلاب والمدرسين",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "level": { "type": "string" },
        "studentCount": { "type": "number" },
        "meetLink": { "type": "string" },
        "schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "startTime": { "type": "string" },
              "endTime": { "type": "string" }
            }
          }
        }
      }
    },
    "Attendance": {
      "title": "سجل الحضور",
      "description": "تسجيل حضور المستخدمين للحصص المباشرة",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userType": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "meetLink": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "TeacherSession": {
       "title": "حصة أستاذ",
       "description": "سجل الحصص التي قدمها الأستاذ",
       "type": "object",
       "properties": {
         "teacherId": { "type": "string" },
         "level": { "type": "string" },
         "subject": { "type": "string" },
         "date": { "type": "string", "format": "date-time" },
         "students": { "type": "number" },
         "status": { "type": "string", "enum": ["pending", "confirmed", "rejected"] },
         "createdAt": { "type": "string", "format": "date-time" }
       }
    },
    "ParentChild": {
       "title": "ربط ولي - تلميذ",
       "description": "بيانات الربط بين حساب الولي وحساب التلميذ",
       "type": "object",
       "properties": {
         "parentId": { "type": "string" },
         "childId": { "type": "string" },
         "createdAt": { "type": "string", "format": "date-time" }
       }
    },
    "Wallet": {
       "title": "محفظة مالية",
       "description": "إدارة الرصيد والأرباح",
       "type": "object",
       "properties": {
         "userId": { "type": "string" },
         "earned": { "type": "number" },
         "paid": { "type": "number" },
         "balance": { "type": "number" }
       }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "بيانات المستخدمين" },
    "/videos/{videoId}": { "schema": "Video", "description": "مكتبة الدروس" },
    "/receipts/{receiptId}": { "schema": "Receipt", "description": "وصولات الخلاص" },
    "/groups/{groupId}": { "schema": "Group", "description": "المجموعات" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "سجلات الحضور للميت" },
    "/teacherSessions/{sessionId}": { "schema": "TeacherSession", "description": "حصص الأساتذة" },
    "/parentChildren/{linkId}": { "schema": "ParentChild", "description": "ربط الأولياء بالأبناء" },
    "/wallets/{userId}": { "schema": "Wallet", "description": "المحافظ المالية" }
  }
}
